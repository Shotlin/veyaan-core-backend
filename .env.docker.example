# ============================================================
# .env.docker.example — for running the full stack in Docker
# ============================================================
# Copy to .env before running:  cp .env.docker.example .env
# Service hostnames match the docker-compose.yml service names.
# ============================================================

# Application
ENVIRONMENT=development
SERVICE_VERSION=0.1.0
API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Supabase — replace YOUR_PROJECT with your actual Supabase project ref
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# PostgreSQL — asyncpg driver required; hostname is the compose service name
DATABASE_URL=postgresql+asyncpg://veyaan:dev_password@postgres:5432/veyaan_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# NATS JetStream — hostname is the compose service name
NATS_URL=nats://nats:4222
NATS_STREAM_COMMANDS=VEYAAN_COMMANDS
NATS_STREAM_DEVICE_EVENTS=VEYAAN_DEVICE_EVENTS
NATS_STREAM_APPROVALS=VEYAAN_APPROVALS
NATS_STREAM_SECURITY=VEYAAN_SECURITY
NATS_CONSUMER_API=api_consumer
NATS_CONSUMER_GATEWAY=gateway_consumer

# Valkey (Redis-compatible) — hostname is the compose service name
VALKEY_URL=redis://valkey:6379
VALKEY_KEY_PREFIX=veyaan:dev:
VALKEY_DEFAULT_TTL=300

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=90
WS_MAX_MESSAGE_SIZE=1048576
WS_SUPPORTED_PROTOCOLS=["v1"]

# Cloudflare R2 — leave blank to disable R2 locally
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=veyaan-dev
R2_ENDPOINT_URL=
R2_PUBLIC_URL=

# Security
DEVICE_CREDENTIAL_TTL_DAYS=365
PAIRING_CODE_TTL_MINUTES=10
MAX_PAIRING_ATTEMPTS=5
APPROVAL_TTL_MINUTES=30
IDEMPOTENCY_TTL_HOURS=24
EMERGENCY_STOP_CACHE_TTL=60
COMMAND_DEFAULT_TTL_MINUTES=1440
COMMAND_MAX_TTL_MINUTES=10080

# Trusted reverse proxies (leave empty for direct access without Caddy)
TRUSTED_PROXY_IPS=[]

# Rate Limits
RATE_LIMIT_AUTH_FAILURES=5
RATE_LIMIT_PAIRING=3
RATE_LIMIT_COMMANDS=30
RATE_LIMIT_APPROVALS=10
RATE_LIMIT_WS_CONNECTIONS=5
RATE_LIMIT_HEALTH_DETAIL=30

# Monitoring
LOG_LEVEL=DEBUG
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
